{
  "schema_version": "v7_protocol_inventory_2026-05-21",
  "purpose": "Protocol feature inventory for protocol-conditioned LFP lifetime modeling.",
  "target_leakage_policy": {
    "eol_definition": "excluded_from_model_inputs",
    "cycle_life": "excluded_from_model_inputs",
    "rul": "excluded_from_model_inputs"
  },
  "feature_schema": {
    "physical_numeric_features": [
      "charge_c_rate_stage1",
      "charge_soc_switch_fraction",
      "charge_c_rate_stage2",
      "discharge_c_rate_stage1",
      "discharge_c_rate_stage2",
      "discharge_c_rate_stage3",
      "temperature_C",
      "depth_of_discharge_fraction",
      "nominal_capacity_Ah",
      "voltage_min_V",
      "voltage_max_V"
    ],
    "physical_categorical_features": {
      "charge_rule": [
        "two_step_fast_charge_cc",
        "constant_current",
        "unknown"
      ],
      "discharge_rule": [
        "constant_current",
        "multi_stage_constant_current",
        "unknown"
      ],
      "form_factor": [
        "18650",
        "26650",
        "unknown"
      ]
    },
    "dataset_identity": [
      "tri_severson",
      "hust_ma",
      "calce_a123"
    ],
    "encoding_notes": [
      "Physical protocol features and dataset identity are encoded separately.",
      "Each physical numeric feature is emitted as value plus an is_known mask.",
      "Unknown numeric values are encoded as 0.0 with mask 0.0.",
      "Not-applicable stage values are encoded as 0.0 with mask 0.0 and are tracked separately from unknown metadata in this inventory.",
      "EOL definitions and cycle_life are evaluation metadata only and are never included in model vectors."
    ]
  },
